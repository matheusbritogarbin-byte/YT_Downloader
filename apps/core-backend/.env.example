# ==============================================================================
# CONFIGURAÇÕES GLOBAIS DA API
# ==============================================================================
PROJECT_NAME="YT Downloader - Industrial API"
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# ==============================================================================
# CRIPTOGRAFIA E SESSÃO DO USUÁRIO (JWT)
# ==============================================================================
# Gere uma chave simétrica forte de 32 bytes (ex: rodando 'openssl rand -hex 32')
JWT_SECRET_KEY=sua_chave_secreta_longa_e_aleatoria_aqui
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ==============================================================================
# GATEWAY DE PAGAMENTOS (STRIPE)
# ==============================================================================
# Chave Secreta de Testes obtida em ://stripe.com (Começa com sk_test_...)
STRIPE_SECRET_KEY=sk_test_substitua_pela_sua_chave_secreta

# Chave de assinatura obtida ao configurar o webhook no Stripe (Começa com whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_substitua_pelo_seu_segredo_do_webhook

# ID do Produto de Assinatura Recorrente Mensal de R$ 4,99 (Começa com price_...)
STRIPE_PRICE_ID_PREMIUM=price_substitua_pelo_id_do_seu_preco

# ==============================================================================
# INFRAESTRUTURA DE BANCO / CACHE
# ==============================================================================
# String de conexão do Redis fornecida automaticamente pelo painel do Railway
REDIS_URL=redis://localhost:6379/0
